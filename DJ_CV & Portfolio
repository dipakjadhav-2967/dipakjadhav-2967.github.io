<script>
function scrollTo(id){
  var target=document.getElementById(id);
  if(!target) return;
  var top=target.getBoundingClientRect().top+window.pageYOffset-110;
  window.scrollTo({top:top,behavior:'smooth'});
}

// Skill card entrance
var cardObserver=new IntersectionObserver(function(entries){
  entries.forEach(function(entry){
    if(entry.isIntersecting){
      entry.target.classList.add('card-visible');
    }
  });
},{threshold:0.2});
document.querySelectorAll('.skill-card').forEach(function(card){
  cardObserver.observe(card);
});

function openPopup(){document.getElementById('phonePopup').classList.add('open');document.body.style.overflow='hidden';}
function closePopup(){document.getElementById('phonePopup').classList.remove('open');document.body.style.overflow='';}
function closeOnOverlay(e){if(e.target===document.getElementById('phonePopup'))closePopup();}
document.addEventListener('keydown',function(e){if(e.key==='Escape')closePopup();});

// Scroll reveal
var observer=new IntersectionObserver(function(entries){
  entries.forEach(function(entry){
    if(entry.isIntersecting){
      entry.target.classList.add('visible');
      // animate sec-rule width
      if(entry.target.classList.contains('sec-rule')) entry.target.style.width='36px';
    }
  });
},{threshold:0.15});

document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.stagger,.sec-rule').forEach(function(el){
  observer.observe(el);
});

// Stat counter animation
function animateCounter(el,target,suffix){
  var start=0;var duration=1200;var step=target/60;var current=0;
  var timer=setInterval(function(){
    current+=step;
    if(current>=target){current=target;clearInterval(timer);}
    el.textContent=Math.floor(current)+(suffix||'');
  },duration/60);
}
var statsObserver=new IntersectionObserver(function(entries){
  entries.forEach(function(entry){
    if(entry.isIntersecting){
      var nums=entry.target.querySelectorAll('.stat-num');
      var data=[{v:8,s:'+'},{v:100,s:'+'},{v:5,s:''},{v:5,s:'+'}];
      nums.forEach(function(el,i){if(data[i])animateCounter(el,data[i].v,data[i].s);});
      statsObserver.unobserve(entry.target);
    }
  });
},{threshold:0.3});
var statsEl=document.querySelector('.hero-stats');
if(statsEl)statsObserver.observe(statsEl);
</script>
