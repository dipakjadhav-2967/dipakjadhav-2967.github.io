<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Dipak Jadhav — Lead Graphic Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:#fff;color:#0d0d0d;font-family:'DM Sans',sans-serif;font-weight:300;line-height:1.6;overflow-x:hidden;}
/* offset anchor targets below fixed nav+ticker (~105px) */
section[id],div[id]{scroll-margin-top:110px;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:center;padding:12px 0;background:#fff;border-bottom:none;}
.nav-links{display:flex;}
.nav-links a.nav-cta{background:#0d0d0d;color:#fff;padding:10px 32px;font-size:11px;font-family:'DM Sans',sans-serif;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;display:inline-block;}
.nav-links a.nav-cta:hover{background:#333;}

/* TICKER */
.ticker-wrap{position:fixed;top:45px;left:0;right:0;z-index:99;overflow:hidden;background:#e8ff47;border-bottom:1px solid #d8ef37;padding:6px 0;white-space:nowrap;}
.ticker-inner{display:inline-block;animation:ticker 32s linear infinite;}
.ticker-inner span{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#0d0d0d;margin:0 28px;}
.ticker-inner span::before{content:'◆  ';}
@keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:160px 40px 100px;border-bottom:1px solid #ebebeb;}
.hero-eyebrow{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:#aaa;margin-bottom:30px;display:inline-flex;align-items:center;gap:12px;}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';display:inline-block;width:32px;height:1px;background:#ddd;}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(64px,11vw,140px);font-weight:900;line-height:0.88;letter-spacing:-0.02em;color:#0d0d0d;}
.hero h1 em{font-style:italic;}
.hero-role{font-family:'DM Mono',monospace;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:#bbb;margin-top:24px;}
.hero-sub{font-size:16px;font-weight:300;color:#888;max-width:500px;margin:16px auto 0;line-height:1.75;}
.hero-stats{display:flex;align-items:stretch;justify-content:center;border:1px solid #ebebeb;max-width:560px;margin:52px auto 0;}
.stat{flex:1;padding:22px 24px;border-right:1px solid #ebebeb;text-align:center;}
.stat:last-child{border-right:none;}
.stat-num{font-family:'Playfair Display',serif;font-size:34px;font-weight:700;color:#0d0d0d;line-height:1;}
.stat-label{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#bbb;margin-top:5px;}
.hero-actions{display:flex;align-items:center;justify-content:center;gap:14px;margin-top:44px;flex-wrap:wrap;}
.btn-primary{background:#0d0d0d;color:#fff;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;padding:14px 32px;transition:background 0.2s;}
.btn-primary:hover{background:#333;}
.btn-outline{border:1px solid #0d0d0d;color:#0d0d0d;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;padding:14px 32px;transition:all 0.2s;}
.btn-outline:hover{background:#0d0d0d;color:#fff;}

/* SECTIONS */
section{padding:96px 60px;border-bottom:1px solid #ebebeb;}
.sec-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#bbb;margin-bottom:14px;text-align:center;}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(32px,4vw,52px);font-weight:700;color:#0d0d0d;line-height:1.1;text-align:center;margin-bottom:12px;}
.sec-title em{font-style:italic;}
.amp{font-family:'DM Sans',sans-serif;font-style:normal;font-weight:300;font-size:0.85em;}
.sec-rule{width:36px;height:1px;background:#0d0d0d;margin:0 auto 56px;}

/* ABOUT */
#about{background:#fafafa;}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid #ebebeb;max-width:900px;margin:0 auto;}
.about-cell{background:#fff;padding:40px 40px;}
.about-cell:first-child{border-right:1px solid #ebebeb;}
.about-cell-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#ccc;margin-bottom:14px;}
.about-cell p{font-size:15px;color:#555;line-height:1.8;}
.skills-list{list-style:none;display:flex;flex-direction:column;gap:0;}
.skills-list li{font-size:13px;color:#555;padding:9px 0;border-bottom:0.5px solid #f0f0f0;display:flex;align-items:center;gap:10px;}
.skills-list li:last-child{border-bottom:none;}
.skills-list li::before{content:'';display:inline-block;width:4px;height:4px;background:#e8ff47;border:1px solid #aaa;flex-shrink:0;}

/* EXPERIENCE */
#experience{background:#fff;}
.exp-list{max-width:860px;margin:0 auto;display:flex;flex-direction:column;gap:0;border:1px solid #ebebeb;}
.exp-item{padding:36px 40px;border-bottom:1px solid #ebebeb;position:relative;transition:background 0.2s;}
.exp-item:last-child{border-bottom:none;}
.exp-item:hover{background:#fafafa;}
.exp-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:6px;flex-wrap:wrap;}
.exp-company{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#0d0d0d;}
.exp-period{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#bbb;white-space:nowrap;padding-top:4px;}
.exp-role{font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#888;margin-bottom:16px;}
.exp-dots{display:flex;flex-direction:column;gap:7px;}
.exp-dot{font-size:13px;color:#666;display:flex;align-items:baseline;gap:10px;line-height:1.5;}
.exp-dot::before{content:'—';font-family:'DM Mono',monospace;font-size:10px;color:#ccc;flex-shrink:0;}
.exp-current{position:absolute;top:36px;right:40px;}
.exp-badge{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;background:#e8ff47;color:#0d0d0d;padding:3px 10px;}

/* SKILLS — clean cards */
#skills{background:#fafafa;}
.skills-cards{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1px;background:#e0e0e0;border:1px solid #e0e0e0;}
.skill-card{background:#fff;padding:36px 32px;display:flex;flex-direction:column;gap:20px;position:relative;overflow:hidden;opacity:0;transform:translateY(32px);transition:opacity 0.55s ease,transform 0.55s ease,background 0.2s;}
.skill-card.card-visible{opacity:1;transform:translateY(0);}
.skill-card:nth-child(1){transition-delay:0s;}
.skill-card:nth-child(2){transition-delay:0.12s;}
.skill-card:nth-child(3){transition-delay:0.24s;}
.skill-card:nth-child(4){transition-delay:0.36s;}
.skill-card:hover{background:#fff;}
/* bottom bar slides on hover */
.skill-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:#0d0d0d;transform:scaleX(0);transform-origin:left;transition:transform 0.4s ease;}
.skill-card:hover::before{transform:scaleX(1);}
.skill-card-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#0d0d0d;line-height:1.2;position:relative;}
.skill-card-divider{width:24px;height:1px;background:#e0e0e0;transition:width 0.4s ease,background 0.3s;}
.skill-card:hover .skill-card-divider{width:48px;background:#0d0d0d;}
.skill-back-tags{display:flex;flex-wrap:wrap;gap:6px;position:relative;}
.skill-back-tag{font-size:11px;color:#666;border:0.5px solid #e8e8e8;padding:5px 11px;background:#fafafa;transition:all 0.18s ease;}
.skill-back-tag:hover{background:#0d0d0d;color:#fff;border-color:#0d0d0d;transform:translateY(-1px);}

/* EDUCATION */
#education{background:#fff;}
.edu-list{max-width:860px;margin:0 auto;display:flex;flex-direction:column;gap:0;border:1px solid #ebebeb;}
.edu-item{padding:28px 40px;border-bottom:1px solid #ebebeb;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;transition:background 0.2s;}
.edu-item:last-child{border-bottom:none;}
.edu-item:hover{background:#fafafa;}
.edu-degree{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:#0d0d0d;}
.edu-school{font-size:13px;color:#888;margin-top:3px;}
.edu-year{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.1em;color:#ccc;white-space:nowrap;}

/* CONTACT */
#contact{background:#fafafa;}
.contact-grid{max-width:860px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;border:1px solid #ebebeb;}
.contact-cell{background:#fff;padding:44px 40px;border-right:1px solid #ebebeb;border-bottom:none;transition:background 0.2s;}
.contact-cell:hover{background:#fafafa;}
.contact-cell:nth-child(2){border-right:none;}
.c-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#ccc;margin-bottom:10px;}
.c-val{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#0d0d0d;line-height:1.3;word-break:break-all;cursor:pointer;transition:color 0.2s;}
.c-val:hover{color:#888;}
.c-val a{text-decoration:none;color:inherit;}

/* POPUP */
.popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.popup-overlay.open{display:flex;}
.popup{background:#fff;width:100%;max-width:380px;border:1px solid #ebebeb;padding:40px 36px;position:relative;}
.popup-close{position:absolute;top:16px;right:20px;font-size:20px;cursor:pointer;color:#aaa;background:none;border:none;line-height:1;transition:color 0.2s;}
.popup-close:hover{color:#0d0d0d;}
.popup-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#bbb;margin-bottom:8px;}
.popup-number{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#0d0d0d;margin-bottom:24px;}
.popup-actions{display:flex;flex-direction:column;gap:10px;}
.popup-btn{display:flex;align-items:center;gap:12px;padding:15px 20px;font-size:12px;font-weight:400;letter-spacing:0.08em;text-transform:uppercase;font-family:'DM Sans',sans-serif;text-decoration:none;border:1px solid #ebebeb;color:#444;transition:all 0.2s;cursor:pointer;background:#fff;}
.popup-btn.call{background:#0d0d0d;color:#fff;border-color:#0d0d0d;}
.popup-btn.call:hover{background:#333;}
.popup-btn.whatsapp{color:#25d366;border-color:#25d366;}
.popup-btn.whatsapp:hover{background:#25d366;color:#fff;}
.popup-btn svg{width:16px;height:16px;flex-shrink:0;}

/* CTA */
.cta-section{padding:96px 60px;background:#0d0d0d;text-align:center;position:relative;overflow:hidden;}
.cta-ghost{position:absolute;font-family:'Playfair Display',serif;font-size:clamp(80px,14vw,190px);font-weight:900;color:rgba(255,255,255,0.03);left:50%;top:50%;transform:translate(-50%,-50%);white-space:nowrap;pointer-events:none;}
.cta-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#444;margin-bottom:18px;position:relative;}
.cta-title{font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,64px);font-weight:700;color:#fff;line-height:1.05;margin-bottom:16px;position:relative;}
.cta-title em{font-style:italic;color:#e8ff47;}
.cta-body{font-size:15px;color:#666;max-width:420px;margin:0 auto 40px;line-height:1.7;position:relative;}
.cta-btn{display:inline-flex;align-items:center;gap:12px;background:#e8ff47;color:#0d0d0d;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;padding:16px 36px;position:relative;transition:background 0.2s,transform 0.2s;}
.cta-btn:hover{background:#f5ff70;transform:translateY(-2px);}
.cta-btn svg{width:14px;height:14px;}

/* FOOTER */
footer{padding:26px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;border-top:1px solid #ebebeb;}
.f-name{font-family:'Playfair Display',serif;font-size:14px;font-weight:700;color:#0d0d0d;}
.f-note{font-size:11px;color:#ccc;letter-spacing:0.05em;}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
.hero-eyebrow{animation:fadeUp 0.55s ease 0.1s both;}
.hero h1{animation:fadeUp 0.65s ease 0.22s both;}
.hero-role,.hero-sub{animation:fadeUp 0.6s ease 0.36s both;}
.hero-stats{animation:fadeUp 0.6s ease 0.48s both;}
.hero-actions{animation:fadeUp 0.6s ease 0.58s both;}
@keyframes popIn{from{opacity:0;transform:scale(0.96);}to{opacity:1;transform:scale(1);}}
.popup-overlay.open .popup{animation:popIn 0.2s ease both;}

/* scroll reveal — elements start hidden */
.reveal{opacity:0;transform:translateY(32px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-left{opacity:0;transform:translateX(-28px);transition:opacity 0.6s ease,transform 0.6s ease;}
.reveal-left.visible{opacity:1;transform:translateX(0);}
.reveal-right{opacity:0;transform:translateX(28px);transition:opacity 0.6s ease,transform 0.6s ease;}
.reveal-right.visible{opacity:1;transform:translateX(0);}

/* stagger children */
.stagger > *{opacity:0;transform:translateY(24px);transition:opacity 0.5s ease,transform 0.5s ease;}
.stagger.visible > *:nth-child(1){opacity:1;transform:translateY(0);transition-delay:0s;}
.stagger.visible > *:nth-child(2){opacity:1;transform:translateY(0);transition-delay:0.1s;}
.stagger.visible > *:nth-child(3){opacity:1;transform:translateY(0);transition-delay:0.2s;}
.stagger.visible > *:nth-child(4){opacity:1;transform:translateY(0);transition-delay:0.3s;}
.stagger.visible > *:nth-child(5){opacity:1;transform:translateY(0);transition-delay:0.4s;}

/* skill tag pop on hover */
.skill-tag{transition:all 0.18s ease,transform 0.18s ease;}
.skill-tag:hover{transform:translateY(-2px);}

/* exp item left border slide */
.exp-item{border-left:2px solid transparent;transition:background 0.2s,border-color 0.3s;}
.exp-item:hover{border-left-color:#e8ff47;}

/* edu item slide */
.edu-item{transition:background 0.2s,padding-left 0.2s;}
.edu-item:hover{padding-left:52px;}

/* section title underline draw */
.sec-rule{width:0;height:1px;background:#0d0d0d;margin:0 auto 56px;transition:width 0.7s ease;}
.sec-rule.visible{width:36px;}

/* stat number count-up placeholder */
.stat-num{transition:transform 0.3s ease;}
.stat:hover .stat-num{transform:scale(1.08);}

/* about cell hover */
.about-cell{transition:background 0.2s;}
.about-cell:hover{background:#fafafa;}

/* CTA btn pulse */
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(232,255,71,0.4);}50%{box-shadow:0 0 0 10px rgba(232,255,71,0);}}
.cta-btn{animation:pulse 2.5s ease infinite;}
.cta-btn:hover{animation:none;}

@media(max-width:768px){
  /* NAV */
  nav{padding:10px 16px;}
  .ticker-wrap{top:45px;}

  /* HERO */
  .hero{padding:110px 20px 64px;min-height:auto;}
  .hero-eyebrow{font-size:9px;letter-spacing:0.14em;gap:8px;}
  .hero-eyebrow::before,.hero-eyebrow::after{width:18px;}
  .hero h1{font-size:clamp(56px,16vw,88px);}
  .hero-role{font-size:10px;}
  .hero-sub{font-size:14px;margin-top:12px;}
  .hero-stats{max-width:100%;flex-wrap:wrap;}
  .stat{flex:1 1 45%;padding:16px 12px;border-bottom:1px solid #ebebeb;}
  .stat:nth-child(2){border-right:none;}
  .stat:nth-child(3){border-bottom:none;}
  .stat:nth-child(4){border-bottom:none;border-right:none;}
  .stat-num{font-size:28px;}
  .stat-label{font-size:9px;}
  .hero-scroll{margin-top:40px;}

  /* SECTIONS */
  section{padding:56px 20px;}
  .sec-title{font-size:clamp(28px,8vw,40px);}

  /* ABOUT */
  .about-grid{grid-template-columns:1fr;}
  .about-cell:first-child{border-right:none;border-bottom:1px solid #ebebeb;}
  .about-cell{padding:28px 24px;}

  /* EXPERIENCE */
  .exp-item{padding:24px 20px;}
  .exp-company{font-size:17px;}
  .exp-role{font-size:11px;}
  .exp-period{font-size:9px;}
  .exp-dot{font-size:12px;}
  .exp-badge{font-size:8px;padding:2px 8px;}

  /* SKILLS */
  .skills-cards{grid-template-columns:1fr 1fr;}
  .skill-card{padding:24px 18px;gap:14px;}
  .skill-card-title{font-size:15px;}
  .skill-back-tag{font-size:10px;padding:4px 8px;}

  /* EDUCATION */
  .edu-item{padding:20px 20px;flex-direction:column;align-items:flex-start;gap:6px;}
  .edu-degree{font-size:15px;}
  .edu-year{font-size:10px;}

  /* CTA */
  .cta-section{padding:56px 20px;}
  .cta-title{font-size:clamp(28px,8vw,44px);}
  .cta-body{font-size:14px;}
  .cta-btn{padding:14px 28px;font-size:11px;}

  /* CONTACT */
  .contact-grid{grid-template-columns:1fr;}
  .contact-cell{border-right:none!important;border-bottom:1px solid #ebebeb!important;padding:28px 24px;}
  .contact-cell:last-child{border-bottom:none!important;}
  .c-val{font-size:15px;word-break:break-all;}

  /* POPUP */
  .popup{padding:32px 24px;margin:16px;}

  /* FOOTER */
  footer{padding:20px;flex-direction:column;align-items:flex-start;gap:6px;}
  .f-note{font-size:10px;}
}

@media(max-width:400px){
  .hero h1{font-size:52px;}
  .skills-cards{grid-template-columns:1fr;}
  .stat{flex:1 1 100%;border-right:none!important;border-bottom:1px solid #ebebeb!important;}
  .stat:last-child{border-bottom:none!important;}
}
</style>
</head>
